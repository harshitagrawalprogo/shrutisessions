# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# ── GOOGLE MEET (auto-create a unique room per booking) ──────────────────────
# Run this ONCE: node scripts/get-google-token.js — then paste the token here.
# Steps to get CLIENT_ID + CLIENT_SECRET:
#   1. console.cloud.google.com → New project
#   2. APIs & Services → Enable APIs → search "Google Calendar API" → Enable
#   3. APIs & Services → Credentials → Create credentials → OAuth client ID
#      → Application type: Web application
#      → Authorised redirect URIs: http://localhost:3001/oauth2callback
#   4. Copy Client ID and Client Secret below
#   5. Run: node scripts/get-google-token.js → sign in → copy GOOGLE_REFRESH_TOKEN
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

OWNER_NAME=Shruti Agrawal
                        # Displayed in email headers and footers

FIRST_SESSION_FEE=299   # Session fee in INR (shown in emails and booking page)

